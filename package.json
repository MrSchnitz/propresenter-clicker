{
  "name": "propresenter-remote",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --host\" \"tsx watch server/index.ts\"",
    "build": "vite build",
    "start": "NODE_ENV=production tsx server/index.ts",
    "package": "npm run build && node scripts/package.mjs",
    "build:sidecar": "node scripts/build-sidecar.mjs",
    "tauri": "tauri",
    "tauri:dev": "npm run build:sidecar && tauri dev",
    "tauri:build": "npm run build:sidecar && tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/cli": "^2.11.2",
    "@tauri-apps/plugin-shell": "^2.3.5",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "qrcode.react": "^4.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.1.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@yao-pkg/pkg": "^6.19.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.28.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
