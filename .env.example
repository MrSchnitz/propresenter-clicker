# PP host: "localhost" for PP on the same machine (auto-mapped to the host in
# Docker), or a LAN IP (e.g. 192.168.1.50) for PP on another machine.
PROPRESENTER_HOST=localhost
PROPRESENTER_PORT=49160
PROPRESENTER_PROTOCOL=ws #or rest fot 7.9+ PP version
PROPRESENTER_PASSWORD= #add password from Remote Apps Controller
ADMIN_PIN=1234
APP_PORT=3000
